# Teams bot runtime configuration
# Copy to .env for local development or pass these variables through Docker/your process manager.

# Channel configuration is always read from config/channels.json.
# Copy config/channels.example.json to config/channels.json and set at least one chatId there.

# HTTP server and polling
PORT=3978
POLL_INTERVAL=5000
MAX_AGENTS=3
AGENT_TIMEOUT=3600000
THREAD_TTL=604800000
AGENT_PREFIX=!agent

# Workspaces
# Prefer per-channel workspace values in config/channels.json.
# If a channel omits workspace, APP_WORKSPACE_DIR is used; if this is omitted too, the bot falls back to $HOME.
# APP_WORKSPACE_DIR=/path/to/your/workspace

# Harness
# HARNESS_BIN=/path/to/omp
HARNESS_BASE_ARGS=--print
HARNESS_APPEND_SYSTEM_PROMPT=1
HARNESS_SKIP_PERMISSIONS=1
# HARNESS_DEFAULT_MODEL=openai/gpt-5.5
# ALOLA_HARNESS_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# Teams scripts
# Defaults to $HOME/.claude/skills/m365-teams/scripts and scripts/teams/reply.py.
# TEAMS_SCRIPTS_DIR=$HOME/.claude/skills/m365-teams/scripts
# TEAMS_REPLY_SCRIPT=./scripts/teams/reply.py

# State, logs, and local secret files
APP_STATE_DIR=./state
APP_LOG_DIR=./logs
APP_SECRETS_DIR=./secrets

# LLM/provider secrets for the harness.
# Prefer *_FILE variables, Docker secrets, or files in APP_SECRETS_DIR named openai_api_key, anthropic_api_key, etc.
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
# LLM_GATEWAY_API_KEY_FILE=/run/secrets/llm_gateway_api_key
# Direct values are accepted for local development but are visible to the harness/agent if allowlisted.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Alola routing. The SSH key is passed as a path only for Alola-routed harness runs.
ALOLA_USER=sareeder
ALOLA_LOGIN_NODES=03,04
ALOLA_DEFAULT_LOGIN_NODE=03
ALOLA_DEFAULT_ASIC=gfx90a
ALOLA_DEFAULT_LOGIN_CONTAINER=sareeder-latest_container
ALOLA_IMAGE_TEMPLATE=/cluster/images/hipdnn/hipdnn_latest_{asic}.sqsh
ALOLA_DEFAULT_CONSTRAINT_PREFIX=MARKHAM
ALOLA_DEFAULT_GPU_TIMEOUT=08:00:00
# ALOLA_SSH_KEY_FILE=/run/secrets/alola_ssh_key
# ALOLA_SSH_KEY=/run/secrets/alola_ssh_key
ALOLA_SSH_OPTIONS=-o BatchMode=yes -o StrictHostKeyChecking=yes
ALOLA_GPU_PARTITION=defq
ALOLA_GPU_CPUS_PER_TASK=16
ALOLA_REMOTE_HOME_MOUNT=/home/AMD/sareeder:/home/AMD/sareeder

# Optional stream timeouts for the OMP/provider gateway.
PI_STREAM_FIRST_EVENT_TIMEOUT_MS=600000
PI_STREAM_IDLE_TIMEOUT_MS=600000
