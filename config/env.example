# Generic Teams bot runtime configuration.
# Copy to .env for local development or use these names in Docker/your process manager.
# Monitored chats are configured only in config/channels.json.

# Required only if the harness is not discoverable as `omp`, `oh-my-pi`, or `claude` on PATH.
# HARNESS_BIN=/absolute/path/to/omp

# Optional default workspace when a channel in config/channels.json omits `workspace`.
# Prefer setting workspace per channel.
# APP_WORKSPACE_DIR=/absolute/path/to/workspace

# Teams helper scripts. Defaults assume the m365-teams skill is installed under $HOME.
# TEAMS_SCRIPTS_DIR=$HOME/.claude/skills/m365-teams/scripts
# TEAMS_REPLY_SCRIPT=./scripts/teams/reply.py

# Server and polling defaults.
# PORT=3978
# APP_BIND_HOST=127.0.0.1
# POLL_INTERVAL=5000
# MAX_AGENTS=3
# AGENT_TIMEOUT=3600000
# THREAD_TTL=604800000
# AGENT_PREFIX=!agent

# Runtime state/log/secret directories.
# APP_STATE_DIR=./state
# APP_LOG_DIR=./logs
# APP_SECRETS_DIR=./secrets

# Harness behavior defaults.
# HARNESS_BASE_ARGS=--print
# HARNESS_APPEND_SYSTEM_PROMPT=1
# HARNESS_SKIP_PERMISSIONS=1
# HARNESS_DEFAULT_MODEL=openai/gpt-5.5

# LLM/provider secrets for the harness.
# Prefer *_FILE variables, Docker secrets, or files in APP_SECRETS_DIR named openai_api_key, anthropic_api_key, etc.
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
# LLM_GATEWAY_API_KEY_FILE=/run/secrets/llm_gateway_api_key
# Direct values are accepted for local development but are visible to the harness/agent if allowlisted.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional stream timeouts for OMP/provider gateways.
# PI_STREAM_FIRST_EVENT_TIMEOUT_MS=600000
# PI_STREAM_IDLE_TIMEOUT_MS=600000

# Docker Compose interpolation knobs. These are consumed by compose.yaml, not by the Node app directly.
# BASE_IMAGE=node:20-bookworm-slim
# TEAMS_BOT_IMAGE=teams-bot:latest
# APP_USER=teamsbot
# Set APP_UID/APP_GID to your host uid/gid when mounting a host home with non-1000 ownership.
# APP_UID=1000
# APP_GID=1000
# HOST_WORKSPACE_DIR=/absolute/host/path/to/workspace
# HOST_SECRETS_DIR defaults to ./secrets. Put provider key files there for Docker runs.
# HOST_SECRETS_DIR=./secrets
# HOST_HOME_DIR defaults to $HOME. Override it to mount a dedicated service-account home instead.
# HOST_HOME_DIR=/absolute/host/home
# HOST_BIND_ADDR=127.0.0.1
