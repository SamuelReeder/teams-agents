# Optional remote-session routing configuration.
# Copy selected values into .env only when this bot should route build/test/GPU work through a remote environment.

# Harness model default for remotely routed prompts.
# ALOLA_HARNESS_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# Remote target defaults. Replace placeholders with deployment-specific values in .env.
# ALOLA_USER=remote-user
# ALOLA_LOGIN_NODES=01
# ALOLA_DEFAULT_LOGIN_NODE=01
# ALOLA_DEFAULT_ASIC=gfx000
# ALOLA_DEFAULT_LOGIN_CONTAINER=remote-session
# ALOLA_IMAGE_TEMPLATE=remote_image_{asic}.sqsh
# ALOLA_DEFAULT_CONSTRAINT_PREFIX=
# ALOLA_DEFAULT_GPU_TIMEOUT=08:00:00

# SSH key path secret. For Docker Compose runner mode, use compose.alola.yaml and set
# ALOLA_SSH_KEY_SOURCE; the key is mounted into agent-runner, not teams-bot.
# ALOLA_SSH_KEY_FILE=/run/secrets/remote_ssh_key
# ALOLA_SSH_KEY=/absolute/path/to/remote_ssh_key
# ALOLA_SSH_HOST_TEMPLATE=login-{node}
# ALOLA_SSH_OPTIONS=-o BatchMode=yes -o StrictHostKeyChecking=yes

# GPU allocation/runtime details.
# ALOLA_GPU_PARTITION=defq
# ALOLA_GPU_CPUS_PER_TASK=16
# ALOLA_REMOTE_HOME_MOUNT=/home/remote:/home/remote
# ALOLA_SSH_TIMEOUT_MS=30000
# ALOLA_START_TIMEOUT_MS=60000
# ALOLA_COMMAND_TIMEOUT_MS=1800000

# Override app-level remote-session CLI path if needed.
# ALOLA_SESSION_BIN=./bin/alola-session

# Docker Compose secret source for the remote key mounted into agent-runner.
# ALOLA_SSH_KEY_SOURCE=./secrets/remote_ssh_key
